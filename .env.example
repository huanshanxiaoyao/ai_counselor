# Application
DEBUG=1
APP_PORT=8000

# Database
POSTGRES_DB=ai_counselor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_counselor

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
LLM_DEFAULT_PROVIDER=qwen
LLM_TIMEOUT=12
LLM_MAX_RETRIES=3

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Qwen (Alibaba)
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# MiniMax
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.1
