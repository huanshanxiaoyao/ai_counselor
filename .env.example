# Application
DEBUG=1
APP_PORT=8000

# Security — REQUIRED in production (DEBUG=0). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
DJANGO_SECRET_KEY=
# Comma-separated list of hostnames this app should accept.
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=ai_counselor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_counselor

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
LLM_DEFAULT_PROVIDER=qwen
LLM_TIMEOUT=12
LLM_MAX_RETRIES=3

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Qwen (Alibaba)
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_MODELS=qwen-plus,qwen-max,qwen3.5-plus

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

# MiniMax
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.5
MINIMAX_MODELS=MiniMax-M2.5,MiniMax-M2.7

# Doubao (Volcengine/ByteDance)
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-lite-260215
DOUBAO_MODELS=doubao-seed-2-0-lite-260215,doubao-seed-2-0-mini-260215,doubao-seed-2-0-pro-260215
